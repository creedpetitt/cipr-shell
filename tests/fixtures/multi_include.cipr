// Multi-include — verifies that including multiple stdlib files in one
// translation unit compiles and runs correctly with no symbol conflicts.
include "src/lib/std/string.cipr";
include "src/lib/std/time.cipr";

let greeting: @String = str_concat("Hello", " World");
let view: str = string_view(greeting);
print(view);
print(str_len(view));
delete greeting;
